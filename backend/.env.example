# Database
DATABASE_URL="postgresql+asyncpg://activia:activia@localhost:5432/activia_trace"

# JWT
SECRET_KEY="change-me-to-a-random-secret-of-at-least-32-chars"
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Encryption (AES-256 — must be exactly 32 characters)
ENCRYPTION_KEY="change-me-to-a-32-char-key!!"

# Test database (optional — defaults to DATABASE_URL if not set)
TEST_DATABASE_URL="postgresql+asyncpg://activia:activia@localhost:5432/activia_trace_test"

# OpenTelemetry (optional — leave empty to disable)
OTEL_SERVICE_NAME="activia-trace"
OTEL_EXPORTER_OTLP_ENDPOINT=""
