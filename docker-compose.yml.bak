services:
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: activia
      POSTGRES_PASSWORD: activia
      POSTGRES_DB: activia_trace
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U activia -d activia_trace"]
      interval: 5s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./backend
    depends_on:
      postgres:
        condition: service_healthy
    env_file:
      - ./backend/.env
    ports:
      - "8000:8000"

  worker:
    build:
      context: ./backend
    depends_on:
      postgres:
        condition: service_healthy
    env_file:
      - ./backend/.env
    command: ["python", "-m", "app.workers.main"]

volumes:
  pgdata:
